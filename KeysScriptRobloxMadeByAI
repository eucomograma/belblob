local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Exploit Hub | Rayfield Edition",
   LoadingTitle = "Carregando Scripts...",
   LoadingSubtitle = "por Bex",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "GeminiScripts",
      FileName = "MainConfig"
   }
})

-- Abas
local HumanoidTab = Window:CreateTab("Humanoid", 4483362458)
local Esptab = Window:CreateTab("Visual/ESP", 4483345998)
local MiscTab = Window:CreateTab("Misc", 4483362458)

---
-- ABA HUMANOID
---
HumanoidTab:CreateToggle({
   Name = "Infinite Jump",
   CurrentValue = false,
   Callback = function(Value)
      _G.InfJump = Value
      game:GetService("UserInputService").JumpRequest:Connect(function()
         if _G.InfJump then
            local char = game.Players.LocalPlayer.Character
            if char and char:FindFirstChildOfClass("Humanoid") then
               char:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
            end
         end
      end)
   end,
})

local TPWalkSpeed = 1
HumanoidTab:CreateSlider({
   Name = "TPWalk Speed",
   Range = {1, 50},
   Increment = 1,
   Suffix = "Studs",
   CurrentValue = 1,
   Callback = function(Value)
      TPWalkSpeed = Value
   end,
})

HumanoidTab:CreateToggle({
   Name = "Ativar TPWalk",
   CurrentValue = false,
   Callback = function(Value)
      _G.TPWalk = Value
      game:GetService("RunService").Stepped:Connect(function()
         if _G.TPWalk then
            local char = game.Players.LocalPlayer.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if char and hum and hum.MoveDirection.Magnitude > 0 then
               char:TranslateBy(hum.MoveDirection * TPWalkSpeed / 10)
            end
         end
      end)
   end,
})

