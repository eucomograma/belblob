local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "KEYS 🔑 | Hub",
   LoadingTitle = "Otimização Extrema...",
   LoadingSubtitle = "por Bex",
   ConfigurationSaving = {Enabled = true, FolderName = "KeysHub", FileName = "KeysConfig"}
})

-- Variáveis de Controle
local PlayerColor = Color3.fromRGB(255, 0, 0)
local NPCColor = Color3.fromRGB(0, 255, 0)
local ESP_Enabled = false
local NPC_ESP_Enabled = false
local Rainbow_ESP = false
local Speed_Enabled = false
local TargetSpeed = 16

-- Função para Cor Rainbow
local function GetRainbowColor()
    return Color3.fromHSV(tick() % 5 / 5, 1, 1)
end

-- Função para Limpar Chams
local function ClearAllChams()
    for _, v in pairs(workspace:GetDescendants()) do
        if v.Name == "ManusChams" then
            v:Destroy()
        end
    end
end

-- Funções Auxiliares para ESP (Chams)
local function ApplyChams(object, color)
    local targetColor = Rainbow_ESP and GetRainbowColor() or color
    local highlight = object:FindFirstChild("ManusChams")
    if not highlight then
        highlight = Instance.new("Highlight")
        highlight.Name = "ManusChams"
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.FillTransparency = 0.5
        highlight.Parent = object
    end
    highlight.FillColor = targetColor
end

-- Loop de Velocidade (Separado para ser instantâneo)
task.spawn(function()
    while task.wait() do
        if Speed_Enabled then
            local char = game.Players.LocalPlayer.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if hum then
                hum.WalkSpeed = TargetSpeed
            end
        end
    end
end)

-- Loop de ESP (Otimizado: Roda a cada 1 segundo para evitar lag)
task.spawn(function()
    while task.wait(1) do
        if not ESP_Enabled and not NPC_ESP_Enabled then
            -- Se ambos desligados, não faz nada (economiza CPU)
        else
            -- ESP Jogadores
            if ESP_Enabled then
                for _, player in pairs(game.Players:GetPlayers()) do
                    if player ~= game.Players.LocalPlayer and player.Character then
                        ApplyChams(player.Character, PlayerColor)
                    end
                end
            end
            
            -- ESP NPCs (Busca apenas por modelos com Humanoid)
            if NPC_ESP_Enabled then
                for _, obj in pairs(workspace:GetChildren()) do -- GetChildren é MUITO mais leve que GetDescendants
                    if obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") and not game.Players:GetPlayerFromCharacter(obj) then
                        ApplyChams(obj, NPCColor)
                    end
                end
            end
        end
    end
end)

--- ABA HUMANOID ---
local TabHumanoid = Window:CreateTab("Humanoid", 4483362458)

TabHumanoid:CreateToggle({
   Name = "Ativar Velocidade Forçada",
   CurrentValue = false,
   Callback = function(Value)
      Speed_Enabled = Value
      if not Value then
          local hum = game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
          if hum then hum.WalkSpeed = 16 end
      end
   end,
})

TabHumanoid:CreateSlider({
   Name = "Velocidade",
   Range = {16, 300},
   Increment = 1,
   Suffix = " Speed",
   CurrentValue = 16,
   Callback = function(Value) TargetSpeed = Value end,
})

TabHumanoid:CreateToggle({
   Name = "Pulo Infinito",
   CurrentValue = false,
   Callback = function(Value)
      _G.InfJump = Value
      game:GetService("UserInputService").JumpRequest:Connect(function()
          if _G.InfJump and game.Players.LocalPlayer.Character then
              game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
          end
      end)
   end,
})

TabHumanoid:CreateToggle({
   Name = "Noclip",
   CurrentValue = false,
   Callback = function(Value)
      _G.Noclip = Value
      game:GetService("RunService").Stepped:Connect(function()
          if _G.Noclip and game.Players.LocalPlayer.Character then
              for _, v in pairs(game.Players.LocalPlayer.Character:GetDescendants()) do
                  if v:IsA("BasePart") then v.CanCollide = false end
              end
          end
      end)
   end,
})

--- ABA ESP ---
local TabESP = Window:CreateTab("Visuals (ESP)", 4483362458)

TabESP:CreateToggle({
   Name = "ESP Colorido (Rainbow Mode)",
   CurrentValue = false,
   Callback = function(Value) Rainbow_ESP = Value end,
})

TabESP:CreateSection("Jogadores")
TabESP:CreateToggle({
   Name = "Ativar ESP Jogadores",
   CurrentValue = false,
   Callback = function(Value) 
      ESP_Enabled = Value 
      if not Value then ClearAllChams() end
   end,
})

TabESP:CreateSection("NPCs")
TabESP:CreateToggle({
   Name = "Ativar ESP NPCs",
   CurrentValue = false,
   Callback = function(Value) 
      NPC_ESP_Enabled = Value 
      if not Value then ClearAllChams() end
   end,
})

