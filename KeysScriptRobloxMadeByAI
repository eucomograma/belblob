    Callback = function(Value) NPCColor = Value end
})

--- ABA MISC ---
local TabMisc = Window:CreateTab("Misc", 4483362458)

TabMisc:CreateToggle({
   Name = "No Prompt Cooldown (Otimizado)",
   CurrentValue = false,
   Callback = function(Value)
      _G.NoPromptCooldown = Value
      if Value then
          -- Método Otimizado: Altera os existentes e monitora novos sem loop pesado
          for _, v in pairs(game:GetDescendants()) do
              if v:IsA("ProximityPrompt") then
                  v.HoldDuration = 0
              end
          end
          -- Conexão para novos itens que aparecerem no mapa
          _G.PromptConnection = game.DescendantAdded:Connect(function(v)
              if _G.NoPromptCooldown and v:IsA("ProximityPrompt") then
                  v.HoldDuration = 0
              end
          end)
      else
          if _G.PromptConnection then _G.PromptConnection:Disconnect() end
      end
   end,
})

Rayfield:LoadConfiguration()
