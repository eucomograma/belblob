--- ABA MISC ---
local TabMisc = Window:CreateTab("Misc", 4483362458)

TabMisc:CreateToggle({
   Name = "No Prompt Cooldown (Zero Lag)",
   CurrentValue = false,
   Callback = function(Value)
      _G.NoPromptCooldown = Value
      if Value then
          -- Método de Alta Performance: Usa o serviço nativo de Prompts
          game:GetService("ProximityPromptService").PromptButtonHoldBegan:Connect(function(prompt)
              if _G.NoPromptCooldown then
                  fireproximityprompt(prompt) -- Tenta completar instantaneamente se o executor suportar
                  prompt.HoldDuration = 0
              end
          end)
          -- Também limpa os que já existem uma única vez
          for _, v in pairs(game:GetDescendants()) do
              if v:IsA("ProximityPrompt") then v.HoldDuration = 0 end
          end
      end
   end,
})

