-- Variáveis de Controle
local ESP_Enabled = false
local NPC_ESP_Enabled = false
local NPC_Names_Enabled = false
local Rainbow_ESP = false
local Chams_Mode = "Fill" 
local AnimSpeed_Enabled = false
local AnimSpeed_Value = 1
local Gravity_Enabled = false
local Gravity_Value = 196

local PlayerColor = Color3.fromRGB(255, 0, 0)
local NPCColor = Color3.fromRGB(0, 255, 0)

-- Função Rainbow
local function GetRainbowColor()
    return Color3.fromHSV(tick() % 5 / 5, 1, 1)
end

-- Função para criar/atualizar Billboard (Nome e Distância)
local function UpdateBillboard(parent, text)
    local head = parent:FindFirstChild("Head")
    if head then
        local billboard = head:FindFirstChild("ManusESP")
        if not billboard then
            billboard = Instance.new("BillboardGui")
            billboard.Name = "ManusESP"
            billboard.Size = UDim2.new(0, 200, 0, 50)
            billboard.Adornee = head
            billboard.AlwaysOnTop = true
            billboard.StudsOffset = Vector3.new(0, 3, 0)
            
            local label = Instance.new("TextLabel")
            label.Parent = billboard
            label.BackgroundTransparency = 1
            label.Size = UDim2.new(1, 0, 1, 0)
            label.Font = Enum.Font.SourceSansBold
            label.TextSize = 14
            label.TextStrokeTransparency = 0
            label.TextColor3 = Color3.new(1, 1, 1)
            billboard.Parent = head
        end
        billboard.TextLabel.Text = text
    end
end

-- Gerenciador de Visuals
local function ApplyVisuals(parent, color)
    local highlight = parent:FindFirstChild("ManusHighlight")
    if not highlight then
        highlight = Instance.new("Highlight")
        highlight.Name = "ManusHighlight"
        highlight.Parent = parent
    end
    
    local targetColor = Rainbow_ESP and GetRainbowColor() or color
    
    if Chams_Mode == "Outline" then
        highlight.FillTransparency = 1
        highlight.OutlineTransparency = 0
        highlight.OutlineColor = targetColor
    else
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0
        highlight.FillColor = targetColor
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    end
end

-- Loop Principal
task.spawn(function()
    while task.wait(0.1) do
        workspace.Gravity = Gravity_Enabled and Gravity_Value or 196.2
        
        pcall(function()
            local char = game.Players.LocalPlayer.Character
            if char and char:FindFirstChild("Humanoid") then
                local animator = char.Humanoid:FindFirstChildOfClass("Animator")
                if animator then
                    for _, track in pairs(animator:GetPlayingAnimationTracks()) do
                        track:AdjustSpeed(AnimSpeed_Enabled and AnimSpeed_Value or 1)
                    end
                end
            end
        end)

        if not ESP_Enabled and not NPC_ESP_Enabled then
            for _, v in pairs(workspace:GetDescendants()) do
                if v.Name == "ManusHighlight" or v.Name == "ManusESP" then v:Destroy() end
            end
        else
            if ESP_Enabled then
                for _, p in pairs(game.Players:GetPlayers()) do
                    if p ~= game.Players.LocalPlayer and p.Character then
                        ApplyVisuals(p.Character, PlayerColor)
                    end
                end
            end
            if NPC_ESP_Enabled then
                for _, v in pairs(workspace:GetDescendants()) do
                    if v:IsA("Humanoid") and v.Parent and not game.Players:GetPlayerFromCharacter(v.Parent) then
                        ApplyVisuals(v.Parent, NPCColor)
                        if NPC_Names_Enabled then
                            pcall(function()
                                local dist = math.floor((game.Players.LocalPlayer.Character.HumanoidRootPart.Position - v.Parent.HumanoidRootPart.Position).Magnitude)
                                UpdateBillboard(v.Parent, v.Parent.Name .. " [" .. dist .. "m]")
                            end)
                        elseif v.Parent:FindFirstChild("Head") and v.Parent.Head:FindFirstChild("ManusESP") then
                            v.Parent.Head.ManusESP:Destroy()
                        end
                    end
                end
            end
        end
    end
end)

