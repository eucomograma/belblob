-- SECTION: DOOR ESP (EXITROOT)
Esptab:CreateSection("Door ESP (ExitRoot)")

Esptab:CreateToggle({
   Name = "Enable Door ESP",
   CurrentValue = false,
   Callback = function(Value)
      _G.DoorESP = Value
      task.spawn(function()
         while _G.DoorESP do
            for _, obj in pairs(workspace:GetDescendants()) do
               if obj.Name == "ExitRoot" and obj:IsA("BasePart") then
                  -- Highlight
                  local hl = obj:FindFirstChild("DoorHighlight")
                  if not hl then
                     hl = Instance.new("Highlight")
                     hl.Name = "DoorHighlight"
                     hl.Parent = obj
                  end
                  hl.FillColor = _G.DoorESPColor
                  hl.OutlineColor = Color3.new(1, 1, 1)
                  hl.FillTransparency = 0.5
                  hl.OutlineTransparency = 0
                  hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                  
                  -- Billboard Distance
                  local bgui = obj:FindFirstChild("DoorGui")
                  if not bgui then
                     bgui = Instance.new("BillboardGui", obj)
                     bgui.Name = "DoorGui"
                     bgui.Size = UDim2.new(0, 200, 0, 50)
                     bgui.AlwaysOnTop = true
                     bgui.StudsOffset = Vector3.new(0, 2, 0)
                     
                     local lbl = Instance.new("TextLabel", bgui)
                     lbl.Size = UDim2.new(1, 0, 1, 0)
                     lbl.BackgroundTransparency = 1
                     lbl.TextColor3 = Color3.new(1, 1, 1)
                     lbl.TextStrokeTransparency = 0
                     lbl.Font = Enum.Font.SourceSansBold
                     lbl.TextSize = 14
                  end
                  
                  local lp = game.Players.LocalPlayer
                  if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                     local dist = (lp.Character.HumanoidRootPart.Position - obj.Position).Magnitude
                     bgui.TextLabel.Text = string.format("Door [%d studs]", math.floor(dist))
                  end
               end
            end
            task.wait(0.5)
         end
         -- Cleanup
         if not _G.DoorESP then
            for _, obj in pairs(workspace:GetDescendants()) do
               if obj.Name == "ExitRoot" then
                  if obj:FindFirstChild("DoorHighlight") then obj.DoorHighlight:Destroy() end
                  if obj:FindFirstChild("DoorGui") then obj.DoorGui:Destroy() end
               end
            end
         end
      end)
   end,
})

Esptab:CreateColorPicker({
    Name = "Door ESP Color",
    Color = _G.DoorESPColor,
    Callback = function(Value)
        _G.DoorESPColor = Value
    end
})

