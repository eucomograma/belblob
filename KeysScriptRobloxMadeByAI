local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Exploit Hub | Rayfield Edition",
   LoadingTitle = "Carregando Scripts...",
   LoadingSubtitle = "por Bex",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "GeminiScripts",
      FileName = "MainConfig"
   }
})

local MainTab = Window:CreateTab("Principal", 4483362458) -- Ícone de exemplo

---
-- 1. NPC HIGHLIGHT (ESP)
---
MainTab:CreateToggle({
   Name = "NPC Highlight (ESP)",
   CurrentValue = false,
   Callback = function(Value)
      _G.NPCHighlight = Value
      while _G.NPCHighlight do
         for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("Model") and v:FindFirstChild("Humanoid") and not game.Players:GetPlayerFromCharacter(v) then
               if not v:FindFirstChild("Highlight") then
                  local hl = Instance.new("Highlight", v)
                  hl.FillColor = Color3.fromRGB(255, 0, 0)
                  hl.OutlineColor = Color3.fromRGB(255, 255, 255)
               end
            end
         end
         task.wait(2)
      end
      if not Value then
         for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("Highlight") then v:Destroy() end
         end
      end
   end,
})

---
-- 2. NO COOLDOWN PROXIMITY PROMPT
---
MainTab:CreateToggle({
   Name = "Instant Proximity Prompt",
   CurrentValue = false,
   Callback = function(Value)
      _G.InstantPrompt = Value
      game:GetService("ProximityPromptService").PromptButtonHoldBegan:Connect(function(prompt)
         if _G.InstantPrompt then
            fireproximityprompt(prompt)
         end
      end)
   end,
})

---
-- 3. INFINITE JUMP
---
MainTab:CreateToggle({
   Name = "Infinite Jump",
   CurrentValue = false,
   Callback = function(Value)
      _G.InfJump = Value
      game:GetService("UserInputService").JumpRequest:Connect(function()
         if _G.InfJump then
            game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
         end
      end)
   end,
})

---
-- 4. TP WALK (Velocidade via Teleporte)
---
local TPWalkSpeed = 1
MainTab:CreateSlider({
   Name = "TPWalk Speed",
   Range = {1, 50},
   Increment = 1,
   Suffix = "Studs",
   CurrentValue = 1,
   Callback = function(Value)
      TPWalkSpeed = Value
   end,
})

MainTab:CreateToggle({
   Name = "Ativar TPWalk",
   CurrentValue = false,
   Callback = function(Value)
      _G.TPWalk = Value
      game:GetService("RunService").Stepped:Connect(function()
         if _G.TPWalk then
            local char = game.Players.LocalPlayer.Character
            local hum = char:FindFirstChildOfClass("Humanoid")
            if char and hum and hum.MoveDirection.Magnitude > 0 then
               char:TranslateBy(hum.MoveDirection * TPWalkSpeed / 10)
            end
         end
      end)
   end,
})

Rayfield:LoadConfiguration()
