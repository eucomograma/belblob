-- Variáveis de Cores Globais
_G.NPCFixoColor = Color3.fromRGB(255, 0, 0)
_G.PlayerOutlineColor = Color3.fromRGB(255, 255, 255)
_G.NPCOutlineColor = Color3.fromRGB(255, 255, 255)

-- Abas
local HumanoidTab = Window:CreateTab("Humanoid", 4483362458)
local Esptab = Window:CreateTab("Visual/ESP", 4483345998)
