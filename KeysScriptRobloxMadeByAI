-- Variáveis de Controle
local NPC_ESP_Enabled = false
local NPC_Names_Enabled = false
local Rainbow_ESP = false
local AnimSpeed_Enabled = false
local AnimSpeed_Value = 1
local Gravity_Enabled = false
local Gravity_Value = 196
local TPWalk_Enabled = false
local TPWalk_Speed = 1

local NPCColor = Color3.fromRGB(0, 255, 0)

-- Cache para objetos e highlights/billboards criados para otimização de remoção
local activeHighlights = {}
local activeBillboards = {}

-- Função Rainbow (calculada uma vez por frame para múltiplos usos)
local currentRainbowColor = Color3.fromRGB(255, 0, 0) -- Valor inicial
local function UpdateRainbowColor()
    currentRainbowColor = Color3.fromHSV(tick() % 5 / 5, 1, 1)
end

-- Função para criar/atualizar Billboard (Nome e Distância)
local function UpdateBillboard(parent, text, color)
    local head = parent:FindFirstChild("Head")
    if head then
        local billboard = activeBillboards[parent] -- Tenta obter do cache
        if not billboard or not billboard.Parent then
            billboard = Instance.new("BillboardGui")
            billboard.Name = "ManusESP"
            billboard.Size = UDim2.new(0, 200, 0, 50)
            billboard.Adornee = head
            billboard.AlwaysOnTop = true
            billboard.StudsOffset = Vector3.new(0, 3, 0)
            
            local label = Instance.new("TextLabel")
            label.Parent = billboard
            label.BackgroundTransparency = 1
            label.Size = UDim2.new(1, 0, 1, 0)
            label.Font = Enum.Font.SourceSansBold
            label.TextSize = 14
            label.TextStrokeTransparency = 0
            label.TextColor3 = Color3.new(1, 1, 1)
            billboard.Parent = head
            activeBillboards[parent] = billboard -- Adiciona ao cache
        end
        billboard.TextLabel.Text = text
        billboard.TextLabel.TextColor3 = color -- Aplica a cor do ESP ao texto
    end
end

-- Função para remover Billboard
local function RemoveBillboard(parent)
    local billboard = activeBillboards[parent]
    if billboard and billboard.Parent then
        billboard:Destroy()
        activeBillboards[parent] = nil
    end
end

-- Gerenciador de Visuals (agora focado apenas em NPCs)
local function ApplyVisuals(parent, color)
    local highlight = activeHighlights[parent] -- Tenta obter do cache
    if not highlight or not highlight.Parent then
        highlight = Instance.new("Highlight")
        highlight.Name = "ManusHighlight"
        highlight.Parent = parent
        activeHighlights[parent] = highlight -- Adiciona ao cache
    end
    
    local targetColor = Rainbow_ESP and currentRainbowColor or color
    highlight.FillColor = targetColor
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
end

-- Função para remover Highlight
local function RemoveHighlight(parent)
    local highlight = activeHighlights[parent]
    if highlight and highlight.Parent then
        highlight:Destroy()
        activeHighlights[parent] = nil
    end
end

-- LOOP EXCLUSIVO PARA TP WALK (Alta Performance / Sem Lag)
task.spawn(function()
    game:GetService("RunService").Heartbeat:Connect(function()
        if TPWalk_Enabled then
            local char = game.Players.LocalPlayer.Character
            local hum = char and char:FindFirstChild("Humanoid")
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if hum and root and hum.MoveDirection.Magnitude > 0 then
                root.CFrame = root.CFrame + (hum.MoveDirection * (TPWalk_Speed / 10))
            end
        end
    end)
end)

-- Loop Secundário (Visuals e Mundo) - Otimizado para NPC ESP
task.spawn(function()
    while task.wait(0.1) do
        -- Atualiza a cor do arco-íris uma vez por iteração se o modo estiver ativo
        if Rainbow_ESP then
            UpdateRainbowColor()
        end

        workspace.Gravity = Gravity_Enabled and Gravity_Value or 196.2
        
        local localPlayer = game.Players.LocalPlayer
        local localCharacter = localPlayer.Character

        -- Otimização de Animação
        if localCharacter and localCharacter:FindFirstChild("Humanoid") then
            local animator = localCharacter.Humanoid:FindFirstChildOfClass("Animator")
            if animator then
                for _, track in pairs(animator:GetPlayingAnimationTracks()) do
                    track:AdjustSpeed(AnimSpeed_Enabled and AnimSpeed_Value or 1)
                end
            end
        end

        -- Gerenciamento de NPC ESP
        if not NPC_ESP_Enabled then
            -- Se NPC ESP não estiver ativo, remove todos os highlights e billboards ativos
            for parent, highlight in pairs(activeHighlights) do
                RemoveHighlight(parent)
            end
            for parent, billboard in pairs(activeBillboards) do
                RemoveBillboard(parent)
            end
        else
            local npcsToHighlight = {}

            -- Coleta NPCs para highlight (otimizado para evitar GetDescendants() repetido)
            -- Itera apenas pelos children do workspace, que geralmente são modelos ou pastas contendo NPCs
            for _, child in pairs(workspace:GetChildren()) do
                if child:IsA("Model") then
                    local humanoid = child:FindFirstChildOfClass("Humanoid")
                    -- Verifica se é um NPC (tem Humanoid e não é um jogador)
                    if humanoid and not game.Players:GetPlayerFromCharacter(child) then
                        npcsToHighlight[child] = true
                        ApplyVisuals(child, NPCColor)
                        if NPC_Names_Enabled and localCharacter and localCharacter:FindFirstChild("HumanoidRootPart") and child:FindFirstChild("HumanoidRootPart") then
                            local dist = math.floor((localCharacter.HumanoidRootPart.Position - child.HumanoidRootPart.Position).Magnitude)
                            UpdateBillboard(child, child.Name .. " [" .. dist .. "m]", NPCColor)
                        else
                            RemoveBillboard(child)
                        end
                    end
                end
            end

            -- Remove highlights/billboards de entidades que não devem mais ter ESP
            for parent, highlight in pairs(activeHighlights) do
                if not npcsToHighlight[parent] then
                    RemoveHighlight(parent)
                end
            end
            for parent, billboard in pairs(activeBillboards) do
                if not npcsToHighlight[parent] or not NPC_Names_Enabled then -- Remove se não for mais um NPC para highlight ou se o nome não estiver ativado
                    RemoveBillboard(parent)
                end
            end
        end
    end
end)

