-- SEÇÃO: NPC HIGHLIGHT FIXO
Esptab:CreateSection("NPC Highlight (Preenchido)")

Esptab:CreateToggle({
   Name = "Ativar NPC Highlight (Fixo)",
   CurrentValue = false,
   Callback = function(Value)
      _G.NPCHighlight = Value
      task.spawn(function()
         while _G.NPCHighlight do
            for _, v in pairs(workspace:GetDescendants()) do
               if v:IsA("Model") and v:FindFirstChild("Humanoid") and not game.Players:GetPlayerFromCharacter(v) then
                  local hl = v:FindFirstChild("HighlightFixo")
                  if not hl then
                     hl = Instance.new("Highlight")
                     hl.Name = "HighlightFixo"
                     hl.Parent = v
                  end
                  hl.FillColor = _G.NPCFixoColor
                  hl.OutlineColor = _G.NPCFixoColor
                  hl.FillTransparency = 0.5
               end
            end
            task.wait(1)
         end
         if not _G.NPCHighlight then
            for _, v in pairs(workspace:GetDescendants()) do
               if v.Name == "HighlightFixo" then v:Destroy() end
            end
         end
      end)
   end,
})

Esptab:CreateColorPicker({
    Name = "Cor do NPC Highlight",
    Color = _G.NPCFixoColor,
    Callback = function(Value)
        _G.NPCFixoColor = Value
    end
})

-- SEÇÃO: PLAYER OUTLINE
Esptab:CreateSection("Player Outline (Apenas Borda)")

Esptab:CreateToggle({
   Name = "Ativar Player Outline",
   CurrentValue = false,
   Callback = function(Value)
      _G.PlayerOutline = Value
      task.spawn(function()
         while _G.PlayerOutline do
            for _, p in pairs(game.Players:GetPlayers()) do
               if p ~= game.Players.LocalPlayer and p.Character then
                  local hl = p.Character:FindFirstChild("OutlinePlayer")
                  if not hl then
                     hl = Instance.new("Highlight")
                     hl.Name = "OutlinePlayer"
                     hl.Parent = p.Character
                  end
                  hl.FillTransparency = 1
                  hl.OutlineColor = _G.PlayerOutlineColor
                  hl.OutlineTransparency = 0
                  hl.Adornee = p.Character
                  hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
               end
            end
            task.wait(1)
         end
         if not _G.PlayerOutline then
            for _, p in pairs(game.Players:GetPlayers()) do
               if p.Character and p.Character:FindFirstChild("OutlinePlayer") then
                  p.Character.OutlinePlayer:Destroy()
               end
            end
         end
      end)
   end,
})

Esptab:CreateColorPicker({
    Name = "Cor do Player Outline",
    Color = _G.PlayerOutlineColor,
    Callback = function(Value)
        _G.PlayerOutlineColor = Value
    end
})

